# Copy to .env and edit as needed
ADMIN_USER=admin
ADMIN_PASS=change_me
PORT=3000
SESSION_SECRET=change_this_to_a_long_random_value
SESSION_MAX_AGE_HOURS=12

# MySQL settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=barber_appointment_system
DB_CONNECTION_LIMIT=10

# Spam protection
APPOINTMENT_RATE_LIMIT_WINDOW_MINUTES=15
APPOINTMENT_RATE_LIMIT_MAX=5
APPOINTMENT_MAX_ACTIVE_PER_IP=3
APPOINTMENT_MAX_ACTIVE_PER_CUSTOMER=2
TRUST_PROXY=false

# Telegram Bot settings
TELEGRAM_BOT_TOKEN=ex
TELEGRAM_CHAT_ID=ex
